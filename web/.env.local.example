# Copy to .env.local (never commit .env.local — see docs/MVP_CHECKLIST.md)

# Public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Site URL for magic link redirect (local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production: set the same keys in Vercel Project Settings → Environment Variables
# and set NEXT_PUBLIC_SITE_URL to your deployed origin (https://...)
